NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prefer AUTH_SECRET for Vercel/Auth.js. JWT_SECRET remains supported for existing custom auth cookies.
AUTH_SECRET=
NEXTAUTH_SECRET=
JWT_SECRET=

# Optional Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional agent and analytics providers.
OPENROUTER_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENAI_API_KEY=
HF_API_TOKEN=

# Optional contact/email defaults.
EMAIL_ADDRESS=
APP_PASSWORD=
DEFAULT_IMAP_HOST=
DEFAULT_IMAP_PORT=993

# Optional compliance secret encryption. Must be 32 bytes or base64-encoded 32 bytes.
COMPLIANCE_ENCRYPTION_KEY=
